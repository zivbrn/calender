<%- include('layout') %>

<div class="container">
  <div class="cal-header">
    <a href="/calendar?year=<%= prevYear %>&month=<%= prevMonth %>" class="cal-nav-btn" title="חודש קודם">&#8250;</a>
    <h1 class="cal-title"><%= monthName %> <%= year %></h1>
    <a href="/calendar?year=<%= nextYear %>&month=<%= nextMonth %>" class="cal-nav-btn" title="חודש הבא">&#8249;</a>
  </div>

  <div class="cal-grid">
    <% const DAY_LABELS = ['ראשון','שני','שלישי','רביעי','חמישי','שישי','שבת']; %>
    <% for (const d of DAY_LABELS) { %>
      <div class="cal-day-name"><%= d %></div>
    <% } %>

    <% for (let i = 0; i < firstDay; i++) { %>
      <div class="cal-cell cal-cell-empty"></div>
    <% } %>

    <% for (let day = 1; day <= daysInMonth; day++) { %>
      <% const dateISO = `${year}-${String(month).padStart(2,'0')}-${String(day).padStart(2,'0')}`; %>
      <% const dayEvents = eventsByDate[dateISO] || []; %>
      <% const isToday = dateISO === todayISO; %>
      <div class="cal-cell <%= isToday ? 'cal-today' : '' %>">
        <div class="cal-day-num <%= isToday ? 'cal-today-num' : '' %>"><%= day %></div>
        <% for (const ev of dayEvents) { %>
          <% const isPrivate = ev.title.includes('שיעור פרטי'); %>
          <% const hasPhone = isPrivate && !!ev.phone; %>
          <div class="cal-event <%= isPrivate ? 'cal-event-private' : 'cal-event-class' %> <%= hasPhone ? 'cal-event-wa' : '' %>">
            <div class="cal-event-inner">
              <span class="cal-event-time"><%= ev.time %></span>
              <span class="cal-event-name"><%= ev.studentName || ev.title %></span>
            </div>
            <% if (hasPhone) { %>
              <a class="cal-wa-slide"
                 href="whatsapp://send?phone=<%= ev.phone %>"
                 target="_blank" rel="noopener"
                 onclick="event.stopPropagation()">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </a>
            <% } %>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>
</div>

<script>
const isTouch = window.matchMedia('(hover: none)').matches;

document.querySelectorAll('.cal-event-wa').forEach(el => {
  if (isTouch) {
    el.addEventListener('click', (e) => {
      const isOpen = el.classList.contains('wa-open');
      document.querySelectorAll('.cal-event-wa.wa-open').forEach(o => o.classList.remove('wa-open'));
      if (!isOpen) el.classList.add('wa-open');
      e.stopPropagation();
    });
  } else {
    let t;
    el.addEventListener('mouseenter', () => {
      t = setTimeout(() => el.classList.add('wa-open'), 600);
    });
    el.addEventListener('mouseleave', () => {
      clearTimeout(t);
      el.classList.remove('wa-open');
    });
  }
});

document.addEventListener('click', () => {
  document.querySelectorAll('.cal-event-wa.wa-open').forEach(el => el.classList.remove('wa-open'));
});
</script>

<%- include('footer') %>
