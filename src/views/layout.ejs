<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#1a73e8">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>X Campus Sync</title>
  <link rel="stylesheet" href="/css/style.css">
  <script>
    (function() {
      const saved = localStorage.getItem('theme');
      if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    })();
  </script>
</head>
<body>
  <% if (user) { %>
  <nav>
    <a href="/schedule" class="nav-brand">
      <svg width="34" height="34" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Calendar body -->
        <rect x="1.5" y="4" width="19" height="17" rx="3" fill="var(--primary)" opacity="0.13"/>
        <rect x="1.5" y="4" width="19" height="17" rx="3" stroke="var(--primary)" stroke-width="1.7"/>
        <!-- Header bar -->
        <rect x="1.5" y="4" width="19" height="6" rx="3" fill="var(--primary)"/>
        <rect x="1.5" y="7.5" width="19" height="2.5" fill="var(--primary)"/>
        <!-- Pins -->
        <line x1="7" y1="2" x2="7" y2="6.5" stroke="var(--primary)" stroke-width="2" stroke-linecap="round"/>
        <line x1="15" y1="2" x2="15" y2="6.5" stroke="var(--primary)" stroke-width="2" stroke-linecap="round"/>
        <!-- Grid dots -->
        <rect x="5" y="14" width="3.5" height="3" rx="1" fill="var(--primary)" opacity="0.75"/>
        <rect x="10.5" y="14" width="3.5" height="3" rx="1" fill="var(--primary)" opacity="0.4"/>
        <!-- Sync circle arrow (bottom-right, white on primary bg circle) -->
        <circle cx="20" cy="19.5" r="5.5" fill="var(--primary)"/>
        <path d="M17.5 19.5 a2.5 2.5 0 1 1 2.5 2.5" stroke="white" stroke-width="1.6" stroke-linecap="round" fill="none"/>
        <polyline points="17.5,21.8 17.5,19.5 19.8,19.5" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>XSync</span>
    </a>
    <div class="nav-links">
      <a href="/schedule" class="nav-icon-btn <%= currentPath === '/schedule' ? 'nav-active' : '' %>" title="לוח זמנים">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>
        <span class="nav-label">ראשי</span>
      </a>
      <a href="/income" class="nav-icon-btn <%= currentPath === '/income' ? 'nav-active' : '' %>" title="הכנסות">
        <span style="font-size:1.05rem;font-weight:700;line-height:1;">₪</span>
        <span class="nav-label">הכנסות</span>
      </a>
      <a href="/calendar" class="nav-icon-btn <%= currentPath === '/calendar' ? 'nav-active' : '' %>" title="לוח שנה">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><rect x="7" y="14" width="3" height="3" rx="0.5" fill="currentColor" stroke="none"/><rect x="14" y="14" width="3" height="3" rx="0.5" fill="currentColor" stroke="none"/></svg>
        <span class="nav-label">לוח שנה</span>
      </a>
      <a href="/students" class="nav-icon-btn <%= currentPath === '/students' ? 'nav-active' : '' %>" title="תלמידים">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <span class="nav-label">תלמידים</span>
      </a>
      <a href="/settings" class="nav-icon-btn <%= currentPath === '/settings' ? 'nav-active' : '' %>" title="הגדרות">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        <span class="nav-label">הגדרות</span>
      </a>
      <a href="/logout" class="nav-icon-btn" title="התנתקות">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        <span class="nav-label">התנתקות</span>
      </a>
      <span class="nav-user"><%= user.displayName || user.email %></span>
    </div>
  </nav>
  <% } %>

  <main>
    <% if (flash) { %>
      <div class="flash flash-<%= flash.type %>"><%= flash.message %></div>
    <% } %>
